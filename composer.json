{
  "name": "scrutineerhq/scrutinizer",
  "description": "WordPress Performance Profiler",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "homepage": "https://scrutineer.dev/scrutinizer",
  "authors": [
    {
      "name": "The Scrutineer Project",
      "homepage": "https://scrutineer.dev"
    }
  ],
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "wp-coding-standards/wpcs": "^3.0",
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "yoast/phpunit-polyfills": "^2.0",
    "phpunit/phpunit": "^9.6"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "platform": {
      "php": "7.4"
    }
  },
  "scripts": {
    "lint": "phpcs",
    "lint:fix": "phpcbf",
    "test": "phpunit"
  }
}
