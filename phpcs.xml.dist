<?xml version="1.0"?>
<ruleset name="Scrutinizer">
	<description>Coding standards for Scrutinizer</description>

	<file>scrutinizer.php</file>
	<file>includes/</file>

	<arg name="extensions" value="php"/>
	<arg name="colors"/>
	<arg value="sp"/>

	<rule ref="WordPress-Extra">
		<!-- WordPress hook, filter, and REST callbacks have fixed signatures;
		     trailing parameters required by the framework contract are often
		     unused. Suppressing this sniff avoids inconsistent callback
		     signatures or scattered per-line ignores. -->
		<exclude name="Generic.CodeAnalysis.UnusedFunctionParameter"/>
	</rule>
	<rule ref="PHPCompatibilityWP"/>
	<rule ref="WordPress-Docs"/>

	<config name="minimum_supported_wp_version" value="6.0"/>
	<config name="testVersion" value="7.4-"/>

	<!-- PSR-4 autoloading: file names follow namespace path, not class-*.php convention. -->
	<rule ref="WordPress.Files.FileName.NotHyphenatedLowercase">
		<exclude-pattern>includes/</exclude-pattern>
	</rule>
	<rule ref="WordPress.Files.FileName.InvalidClassFileName">
		<exclude-pattern>includes/</exclude-pattern>
	</rule>

	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="scrutinizer"/>
			</property>
		</properties>
	</rule>
</ruleset>
